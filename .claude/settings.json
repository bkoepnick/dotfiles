{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(cat:*)",
      "Bash(echo:*)",
      "Bash(find:*)",
      "Bash(fzf:*)",
      "Bash(gh release view:*)",
      "Bash(gh repo view:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git status)",
      "Bash(grep:*)",
      "Bash(just:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(wc:*)",
      "Bash(which:*)",
      "Bash(jq:*)",
      "Edit(./**)",
      "Read(./**)",
      "Write(./**)"
    ]
  },
  "model": "opus[1m]"
}
